# ==============================================================================
#  bootstrap.toml — full Debian/Ubuntu/Kali dev-workstation setup
# ==============================================================================
#
#  This is the "batteries included" example: a direct translation of the
#  kind of setup script people hand-roll for a fresh Kali/kubuntu/Debian
#  box. Covers the bulk apt prereqs, a Node toolchain, tealdeer, ZimFW,
#  zsh-fzf-history-search, and a `chsh` helper — everything a new host
#  needs on top of the built-in registry (fzf/eza/bat/fd/neovim/neovim-
#  plugins/pet/yazi).
#
#  Copy to your dotfiles repo or ~/.tuck/bootstrap.toml and edit to taste:
#
#      cp "$(npm root -g)/@prnv/tuck/templates/bootstrap.toml.full.example" \
#         ~/dotfiles/bootstrap.toml
#
#  See the minimal starter (`bootstrap.toml.example`) for field reference
#  and interpolation rules.
# ==============================================================================


# ------------------------------------------------------------------------------
# TIER 1 — core shell + network + git (runs first, everything else assumes it)
# ------------------------------------------------------------------------------
[[tool]]
id = "system-prereqs"
description = "Core shell/network/git utilities (zsh, curl, wget, unzip, git)"
category = "base"
# check passes when every one of the core binaries is resolvable — any miss
# triggers the full apt-get install rather than partial-state ambiguity.
check = "command -v zsh >/dev/null && command -v curl >/dev/null && command -v wget >/dev/null && command -v unzip >/dev/null && command -v git >/dev/null"
install = """
set -e
sudo apt-get update
sudo apt-get install -y zsh curl wget unzip git
"""
update = "sudo apt-get install -y --only-upgrade zsh curl wget unzip git"


# ------------------------------------------------------------------------------
# TIER 2 — Node.js toolchain (required before neovim-plugins builds
# tree-sitter-cli). Broken out from dev-utilities so ordering is clear.
# ------------------------------------------------------------------------------
[[tool]]
id = "node-toolchain"
description = "Node.js + npm (required by tree-sitter-cli, etc.)"
category = "base"
requires = ["system-prereqs"]
check = "command -v node >/dev/null && command -v npm >/dev/null"
install = "sudo apt-get install -y nodejs npm"
update = "sudo apt-get install -y --only-upgrade nodejs npm"


# ------------------------------------------------------------------------------
# TIER 3 — dev utilities bulk apt install. Mirrors the deploy_dots.sh
# do_fresh_install PACKAGES list, minus anything the built-in registry
# already handles (fzf/eza/bat/fd/neovim all come from BUILT_IN_TOOLS).
# Grouped into one [[tool]] because the whole point is "run one apt-get".
# ------------------------------------------------------------------------------
[[tool]]
id = "dev-utilities"
description = "CLI utility packages (ripgrep/zoxide/fastfetch/dtrx/lnav/etc.)"
category = "shell"
requires = ["system-prereqs"]
# rg + zoxide + fastfetch is a reasonable signal set — if all three are
# present the bulk install succeeded.
check = "command -v rg >/dev/null && command -v zoxide >/dev/null && command -v fastfetch >/dev/null"
install = """
set -e
sudo apt-get install -y \\
  ripgrep \\
  zoxide \\
  fastfetch \\
  dtrx \\
  lnav \\
  ffmpeg \\
  7zip \\
  jq \\
  poppler-utils \\
  imagemagick \\
  build-essential
"""
update = """
sudo apt-get install -y --only-upgrade \\
  ripgrep zoxide fastfetch dtrx lnav ffmpeg 7zip jq poppler-utils imagemagick build-essential
"""
detect = { paths = [], rcReferences = ["zoxide init"] }


# ------------------------------------------------------------------------------
# TIER 4 — individual tools with non-trivial update semantics
# ------------------------------------------------------------------------------

# tealdeer — simplified man pages. `tldr --update` refreshes the cache
# independently of the package itself, so we run it under `update` even
# when the apt package hasn't changed.
[[tool]]
id = "tealdeer"
description = "simplified man pages (tldr)"
category = "shell"
requires = ["system-prereqs"]
check = "command -v tldr >/dev/null 2>&1"
install = "sudo apt-get install -y tealdeer"
update = """
set -e
sudo apt-get install -y --only-upgrade tealdeer
tldr --update || true
"""
detect = { paths = [], rcReferences = ["tldr"] }


# ------------------------------------------------------------------------------
# TIER 5 — shell framework layer (ZimFW + plugins)
# ------------------------------------------------------------------------------

# ZimFW — modular zsh framework. Installs via `curl | zsh` per upstream.
# Skipped on Kali by default because Kali ships with its own oh-my-zsh-
# style setup; override by removing the guard or omitting the check.
[[tool]]
id = "zim-framework"
description = "ZimFW — modular zsh framework"
category = "shell"
requires = ["system-prereqs"]
# $HOME is shell-expanded (not ${HOME} — tuck only interpolates ${HOME}
# via the inteproplator). Either works; plain $HOME keeps the script
# copy-pasteable outside of tuck.
check = "test -e $HOME/.zim"
install = """
set -e
if [ -f /etc/os-release ] && (. /etc/os-release && [ "$ID" = "kali" ]); then
  echo "Skipping ZimFW on Kali (Kali ships its own zsh setup)."
  exit 0
fi
curl -fsSL https://raw.githubusercontent.com/zimfw/install/master/install.zsh | zsh
"""
update = "@install"
detect = { paths = ["~/.zim"], rcReferences = ["zimfw"] }


# zsh-fzf-history-search — fzf-powered history search. Shares fzf as a
# hard dep so the resolver orders fzf first.
[[tool]]
id = "zsh-fzf-history-search"
description = "fzf-powered zsh history search plugin"
category = "shell"
requires = ["fzf", "system-prereqs"]
check = "test -d $HOME/.zsh/plugins/zsh-fzf-history-search"
install = """
set -e
mkdir -p "$HOME/.zsh/plugins"
if [ ! -d "$HOME/.zsh/plugins/zsh-fzf-history-search" ]; then
  git clone https://github.com/joshskidmore/zsh-fzf-history-search \\
    "$HOME/.zsh/plugins/zsh-fzf-history-search"
fi
"""
# Plugins-in-a-git-clone: `update` pulls the plugin repo rather than
# apt-installing anything. Keep --rebase to stay linear.
update = """
set -e
if [ -d "$HOME/.zsh/plugins/zsh-fzf-history-search/.git" ]; then
  git -C "$HOME/.zsh/plugins/zsh-fzf-history-search" pull --rebase --ff-only
else
  mkdir -p "$HOME/.zsh/plugins"
  git clone https://github.com/joshskidmore/zsh-fzf-history-search \\
    "$HOME/.zsh/plugins/zsh-fzf-history-search"
fi
"""
detect = { paths = ["~/.zsh/plugins/zsh-fzf-history-search"], rcReferences = ["zsh-fzf-history-search"] }


# ------------------------------------------------------------------------------
# TIER 6 — host mutation: switch the login shell to zsh
# ------------------------------------------------------------------------------

# `chsh` is stubbornly interactive under PAM — it asks for your password
# even with -y. We call it under `timeout 5` so a non-cached sudo doesn't
# hang the picker; if it fails we print the manual command. Users who
# don't want this at all should leave the tool out of their bundle.
[[tool]]
id = "chsh-zsh"
description = "switch login shell to zsh (one-time)"
category = "shell"
requires = ["system-prereqs"]
# Check passes when the login shell for this user is already zsh — so
# this tool no-ops after the first successful run.
check = """
test "$(getent passwd \\"$USER\\" | cut -d: -f7)" = "$(command -v zsh)"
"""
install = """
set -e
ZSH_PATH="$(command -v zsh)"
if ! timeout 5 chsh -s "$ZSH_PATH" 2>/dev/null; then
  echo "chsh requires a password. Run manually: chsh -s \\"\\$(command -v zsh)\\""
  exit 1
fi
"""
update = "@install"


# ==============================================================================
#  BUNDLES — named collections invoked with `tuck bootstrap --bundle <name>`
# ==============================================================================
#
#  Tip: bundles are flat lists (no includes/inheritance). `full` is spelled
#  out below — copy-edit to create your own slice.

[bundles]

# `kali` — Kali-specific overlay setup. Skips ZimFW (Kali's shell setup
# is its own thing) and skips chsh (Kali already defaults to zsh in most
# setups). Keeps all the CLIs.
kali = [
  "system-prereqs",
  "node-toolchain",
  "dev-utilities",
  "tealdeer",
  "fzf", "eza", "bat", "fd",              # built-ins
  "neovim", "neovim-plugins",              # built-ins
  "pet", "yazi",                           # built-ins
  "zsh-fzf-history-search",
]

# `full` — the full new-machine setup for non-Kali boxes. Adds ZimFW and
# the chsh step on top of the CLI set.
full = [
  "system-prereqs",
  "node-toolchain",
  "dev-utilities",
  "tealdeer",
  "fzf", "eza", "bat", "fd",               # built-ins
  "neovim", "neovim-plugins",              # built-ins
  "pet", "yazi",                           # built-ins
  "zsh-fzf-history-search",
  "zim-framework",
  "chsh-zsh",
]

# `minimal` — just the CLI toolchain, no shell-framework side-effects.
# Good for servers or ephemeral containers. (Add `"dev-utilities"` if you
# also want ripgrep/zoxide/fastfetch and the rest of the utility bulk.)
minimal = [
  "system-prereqs",
  "fzf", "fd", "bat", "neovim",
]


# ==============================================================================
#  REGISTRY — disable built-ins on a per-host basis
# ==============================================================================
#
#  `disabled` drops the named built-ins from the overlay. User `[[tool]]`
#  entries with the same id still win — `disabled` only affects the
#  built-in registry, not user-declared tools.

[registry]
disabled = []  # e.g. ["yazi"] on a server where you don't want a TUI file manager

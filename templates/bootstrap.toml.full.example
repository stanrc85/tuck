# ==============================================================================
#  bootstrap.toml — full Debian/Ubuntu/Kali dev-workstation setup
# ==============================================================================
#
#  This is the "batteries included" example: a direct translation of the
#  kind of setup script people hand-roll for a fresh Kali/kubuntu/Debian
#  box. Covers the bulk apt prereqs, a Node toolchain, ripgrep/zoxide/
#  tealdeer, ZimFW, zsh-fzf-history-search, and a `chsh` helper.
#
#  v3 has no built-in tool registry — every tool you want bootstrapped
#  must appear in this file as a `[[tool]]` block. The shape below
#  installs the common dev-CLI set via apt; swap to a single
#  `brew install fzf yazi neovim bat fd ripgrep …` line in one tool block
#  if you prefer Linuxbrew (see `brew-cli-utils` pattern in the README).
#
#  Copy to your dotfiles repo or ~/.tuck/bootstrap.toml and edit to taste:
#
#      cp "$(npm root -g)/@prnv/tuck/templates/bootstrap.toml.full.example" \
#         ~/dotfiles/bootstrap.toml
#
#  See the minimal starter (`bootstrap.toml.example`) for field reference
#  and interpolation rules.
# ==============================================================================


# ------------------------------------------------------------------------------
# TIER 1 — core shell + network + git (runs first, everything else assumes it)
# ------------------------------------------------------------------------------
[[tool]]
id = "system-prereqs"
description = "Core shell/network/git utilities (zsh, curl, wget, unzip, git)"
category = "base"
# check passes when every one of the core binaries is resolvable — any miss
# triggers the full apt-get install rather than partial-state ambiguity.
check = "command -v zsh >/dev/null && command -v curl >/dev/null && command -v wget >/dev/null && command -v unzip >/dev/null && command -v git >/dev/null"
install = """
set -e
sudo apt-get update
sudo apt-get install -y zsh curl wget unzip git
"""
update = "sudo apt-get install -y --only-upgrade zsh curl wget unzip git"


# ------------------------------------------------------------------------------
# TIER 2 — Node.js toolchain (required before neovim-plugins builds
# tree-sitter-cli). Broken out so dep ordering is explicit.
# ------------------------------------------------------------------------------
[[tool]]
id = "node-toolchain"
description = "Node.js + npm (required by tree-sitter-cli, etc.)"
category = "base"
requires = ["system-prereqs"]
check = "command -v node >/dev/null && command -v npm >/dev/null"
install = "sudo apt-get install -y nodejs npm"
update = "sudo apt-get install -y --only-upgrade nodejs npm"


# ------------------------------------------------------------------------------
# TIER 3 — dev CLI bulk apt install. One [[tool]] block keeps it to a single
# `apt-get install` invocation. Swap apt for `brew install …` if you prefer
# Linuxbrew across hosts.
# ------------------------------------------------------------------------------
[[tool]]
id = "dev-cli-utils"
description = "common CLI tools (fzf/eza/bat/fd/ripgrep/neovim/yazi/pet/tealdeer/zoxide)"
category = "shell"
requires = ["system-prereqs"]
# `installer` + `packages` shorthand — tuck synthesizes install/check/update
# from this list. Adding or removing a tool is a single-line diff. See the
# Bootstrapping-Tools wiki page for the full schema.
installer = "apt"
packages = [
  "fzf", "eza", "bat", "fd-find", "ripgrep", "neovim", "yazi", "pet",
  "tealdeer", "zoxide", "fastfetch", "dtrx", "lnav", "ffmpeg", "7zip",
  "jq", "poppler-utils", "imagemagick", "build-essential",
]
detect = { paths = [], rcReferences = ["fzf", "eza", "rg", "nvim", "zoxide init"] }


# ------------------------------------------------------------------------------
# TIER 4 — neovim plugin sync (runs `lazy.sync` headlessly + treesitter
# parser install). Requires neovim from dev-cli-utils plus node for
# tree-sitter-cli.
# ------------------------------------------------------------------------------
[[tool]]
id = "neovim-plugins"
description = "sync lazy.nvim-managed neovim plugins"
category = "editors"
requires = ["dev-cli-utils", "node-toolchain"]
check = 'test -d "$HOME/.local/share/nvim/lazy/nvim-treesitter"'
install = """
set -e
if command -v npm >/dev/null 2>&1; then
  sudo npm install -g tree-sitter-cli
fi
nvim --headless \\
  -c 'lua require("lazy").sync({ wait = true, show = false })' \\
  -c 'silent! lua require("lazy").load({ plugins = { "nvim-treesitter" } })' \\
  -c 'silent! TSInstallSync! markdown lua go bash python json yaml toml vim regex' \\
  -c 'qa!'
"""
update = """
nvim --headless -c 'Lazy! sync' -c 'qa!'
"""
detect = { paths = ["~/.config/nvim/lua/plugins", "~/.config/nvim/lazy-lock.json"], rcReferences = [] }
associatedConfig = ["~/.config/nvim/lazy-lock.json", "~/.config/nvim/lua/**"]


# ------------------------------------------------------------------------------
# TIER 5 — shell framework layer (ZimFW + plugins)
# ------------------------------------------------------------------------------

# ZimFW — modular zsh framework. Installs via `curl | zsh` per upstream.
# Skipped on Kali by default because Kali ships with its own oh-my-zsh-
# style setup; override by removing the guard or omitting the check.
[[tool]]
id = "zimfw"
description = "ZimFW — modular zsh framework"
category = "shell"
requires = ["system-prereqs"]
check = """
if [ -f /etc/os-release ] && (. /etc/os-release && [ "$ID" = "kali" ]); then exit 0; fi
test -e $HOME/.zim
"""
install = """
set -e
if [ -f /etc/os-release ] && (. /etc/os-release && [ "$ID" = "kali" ]); then
  echo "Skipping ZimFW on Kali (Kali ships its own zsh setup)."
  exit 0
fi
ZSH_PATH="$(command -v zsh)"
curl -fsSL https://raw.githubusercontent.com/zimfw/install/master/install.zsh | SHELL="$ZSH_PATH" zsh
"""
update = """
zsh -c 'source "${ZIM_HOME:-${ZDOTDIR:-$HOME}/.zim}/init.zsh" && zimfw upgrade && zimfw update'
"""
detect = { paths = ["~/.zim", "~/.zimrc", "~/.config/zsh/.zimrc"], rcReferences = ["zimfw"] }
associatedConfig = ["~/.zimrc", "~/.config/zsh/.zimrc"]


# zsh-fzf-history-search — fzf-powered history search. Requires fzf from
# dev-cli-utils so the resolver orders that bundle first.
[[tool]]
id = "zsh-fzf-history-search"
description = "fzf-powered zsh history search plugin"
category = "shell"
requires = ["dev-cli-utils", "system-prereqs"]
check = "test -d $HOME/.zsh/plugins/zsh-fzf-history-search"
install = """
set -e
mkdir -p "$HOME/.zsh/plugins"
if [ ! -d "$HOME/.zsh/plugins/zsh-fzf-history-search" ]; then
  git clone https://github.com/joshskidmore/zsh-fzf-history-search \\
    "$HOME/.zsh/plugins/zsh-fzf-history-search"
fi
"""
update = """
set -e
if [ -d "$HOME/.zsh/plugins/zsh-fzf-history-search/.git" ]; then
  git -C "$HOME/.zsh/plugins/zsh-fzf-history-search" pull --rebase --ff-only
else
  mkdir -p "$HOME/.zsh/plugins"
  git clone https://github.com/joshskidmore/zsh-fzf-history-search \\
    "$HOME/.zsh/plugins/zsh-fzf-history-search"
fi
"""
detect = { paths = ["~/.zsh/plugins/zsh-fzf-history-search"], rcReferences = ["zsh-fzf-history-search"] }


# ==============================================================================
#  BUNDLES — named collections invoked with `tuck bootstrap --bundle <name>`
# ==============================================================================
#
#  Tip: bundles are flat lists (no includes/inheritance). `full` is spelled
#  out below — copy-edit to create your own slice.

[bundles]

# `kali` — Kali-specific setup. Skips ZimFW (Kali's shell setup is its own
# thing) and skips chsh (Kali already defaults to zsh).
kali = [
  "system-prereqs",
  "node-toolchain",
  "dev-cli-utils",
  "neovim-plugins",
  "zsh-fzf-history-search",
]

# `full` — full new-machine setup for non-Kali boxes. Adds ZimFW on top.
full = [
  "system-prereqs",
  "node-toolchain",
  "dev-cli-utils",
  "neovim-plugins",
  "zsh-fzf-history-search",
  "zimfw",
]

# `minimal` — system prereqs + the CLI bundle, no shell-framework side
# effects. Good for servers or ephemeral containers.
minimal = [
  "system-prereqs",
  "dev-cli-utils",
]

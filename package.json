{
  "name": "@prnv/tuck",
  "version": "2.7.1",
  "private": true,
  "description": "Modern dotfiles manager with a beautiful CLI",
  "keywords": [
    "dotfiles",
    "cli",
    "backup",
    "configuration",
    "git"
  ],
  "homepage": "https://github.com/stanrc85/tuck#readme",
  "bugs": {
    "url": "https://github.com/stanrc85/tuck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stanrc85/tuck.git"
  },
  "license": "MIT",
  "author": "Pranav Karra",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tuck": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run --dir tests/security",
    "test:integration": "vitest run --dir tests/integration",
    "test:unit": "vitest run --dir tests/lib --dir tests/commands",
    "bench": "vitest bench --config vitest.bench.config.ts",
    "bench:watch": "vitest bench --config vitest.bench.config.ts --watch",
    "prepare": "husky install 2>/dev/null || true",
    "prepack": "tsup",
    "prepublishOnly": "pnpm build",
    "build:man": "ts-node scripts/generate-man.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "cosmiconfig": "^9.0.0",
    "figures": "^6.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "log-symbols": "^7.0.1",
    "ora": "^8.0.1",
    "simple-git": "^3.22.0",
    "smol-toml": "^1.6.1",
    "update-notifier": "^7.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@types/update-notifier": "^6.0.8",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "memfs": "^4.6.0",
    "prettier": "^3.2.4",
    "semantic-release": "^23.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]"
        }
      ]
    ]
  }
}
